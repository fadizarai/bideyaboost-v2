# Frontend Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000

# Production Example:
# NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# Site URL for SEO and metadata
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Security Notes:
# 1. Only NEXT_PUBLIC_ variables are exposed to the browser
# 2. Never put sensitive data in NEXT_PUBLIC_ variables
# 3. Backend secrets should be in backend/.env file
# 4. Use HTTPS URLs in production
